LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

OLLAMA_ENDPOINT=https://ollama.aaptor.com/api/generate
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SEC=90
OLLAMA_MAX_RETRIES=3

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=linkedin_ai_scraper
MONGODB_COLLECTION=profiles
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000

MAX_PROFILES_PER_RUN=20
MAX_SEARCH_PAGES=10
MIN_DELAY=8
MAX_DELAY=20
LOGIN_PAGE_TIMEOUT_SEC=30
LOGIN_FORM_TIMEOUT_SEC=45
MANUAL_VERIFICATION_TIMEOUT_SEC=180
BROWSER_HEADLESS=false
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/New_York
BROWSER_WIDTH_MIN=1200
BROWSER_WIDTH_MAX=1400
BROWSER_HEIGHT_MIN=700
BROWSER_HEIGHT_MAX=900

SCHEDULER_ENABLED=true
RUNS_PER_DAY=5
START_HOUR=9
END_HOUR=21
JITTER_MINUTES=15
MIN_GAP_MINUTES=90
TIMEZONE=Asia/Kolkata

APP_HOST=127.0.0.1
APP_PORT=1234
APP_RELOAD=true
